# Fix MIME type for ES module worker files (.mjs)
# Required for pdf.js v5 worker (pdf.worker.min.mjs) to load in browsers.
# Browsers refuse to execute scripts served with wrong MIME type.
# SiteGround supports Apache .htaccess directives via mod_mime.
AddType text/javascript .mjs

# Never cache index.html — it references hashed JS/CSS assets.
# Hashed assets (e.g. index-Abc123.js) are cached forever (immutable).
<Files "index.html">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</Files>

<FilesMatch "\.(js|css|mjs)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
